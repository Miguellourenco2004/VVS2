name: Java CI with Maven

on:
  workflow_dispatch: # Permite correr o CI manualmente no GitHub
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

jobs:
  # --- JOB 1: Testes Unitários e de Integração ---
  build-and-test:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v4

    - name: Set up JDK 17
      uses: actions/setup-java@v4
      with:
        java-version: '17'
        distribution: 'temurin'
        cache: maven

    - name: Run Unit Tests
      run: mvn test -Punit-tests

    - name: Run Integration Tests
      # Ignora os unitários aqui para não perder tempo a repeti-los
      run: mvn verify -Pintegration-tests -Dsurefire.skip=true

  # --- JOB 2: Testes E2E ---
  e2e-tests:
    needs: build-and-test # OBRIGATÓRIO: Este job só corre se o 'build-and-test' passar!
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v4

    - name: Set up JDK 17
      uses: actions/setup-java@v4
      with:
        java-version: '17'
        distribution: 'temurin'
        cache: maven

    - name: Run e2e Tests
      # Ignora os unitários também aqui!
      run: mvn verify -Pe2e-tests -Dsurefire.skip=true